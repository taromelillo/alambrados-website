---
const { description, canonical, title } = Astro.props;
const baseUrl = "https://www.alambradosmelillo.com.ar/";
---

<meta name="description" content={description} />
{
  canonical && (
    <link
      rel="canonical"
      href={`https://www.alambradosmelillo.com.ar${canonical}`}
    />
  )
}

<meta property="og:url" content={baseUrl} />
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={`${baseUrl}og.jpg"`} />
<meta property="og:image:height" content="300" />
<meta property="og:image:width" content="521" />
<meta property="og:locale" content="es_AR" />
<meta
  property="og:site_name"
  content="Cerramientos y Alambrados | Alambrados Melillo"
/>

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={`${baseUrl}og.jpg"`} />


